# =============================================================================
# Variables de entorno — PAME Frontend
# =============================================================================
# Copia este archivo a .env.local y ajusta los valores según tu entorno.
# .env.local está en .gitignore y nunca se sube al repositorio.
#
# Uso:
#   cp .env.example .env.local
# =============================================================================

# URL base del backend Django.
# El frontend antepone esta URL a todas las llamadas al API (PlanService, etc.).
# Desarrollo local: http://localhost:8000
# Producción:       https://api.tu-dominio.com
VITE_API_BASE_URL=http://localhost:8000
